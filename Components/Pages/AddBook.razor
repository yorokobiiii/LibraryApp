@page "/addbook"
@using LibraryApp.Models
@using LibraryApp.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components
@inject IBookService BookService
@inject NavigationManager Navigation

<h3>➕ Добавление новой книги</h3>

<EditForm FormName="addbook" Model="@newBook" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger" />

    <div class="mb-3">
        <label class="form-label">Название *</label>
        <InputText class="form-control" @bind-Value="newBook.Title" />
        <ValidationMessage For="@(() => newBook.Title)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Автор *</label>
        <InputText class="form-control" @bind-Value="newBook.Author" />
        <ValidationMessage For="@(() => newBook.Author)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Жанр</label>
        <InputText class="form-control" @bind-Value="newBook.Genre" />
    </div>

    <div class="mb-3">
        <label class="form-label">Год</label>
        <InputNumber TValue="int" class="form-control" @bind-Value="newBook.Year" />
        <ValidationMessage For="@(() => newBook.Year)" />
    </div>

    <div class="mb-3">
        <button type="submit" class="btn btn-primary">💾 Сохранить</button>
        <button type="button" class="btn btn-secondary" @onclick="GoToBooks">📚 К списку книг</button>
    </div>
</EditForm>

@code {
    private Book newBook = new Book();

    private async Task HandleValidSubmit()
    {
        if (string.IsNullOrWhiteSpace(newBook.Title))
        {
            return;
        }
        
        if (string.IsNullOrWhiteSpace(newBook.Author))
        {
            return;
        }

        await BookService.AddBookAsync(newBook);
        Navigation.NavigateTo("/books");
    }

    private void GoToBooks()
    {
        Navigation.NavigateTo("/books");
    }
}