@page "/addbook"
@using LibraryApp.Models
@using LibraryApp.Services
@inject IBookService BookService
@inject NavigationManager Navigation

<h3>➕ Добавление новой книги</h3>

<div class="mb-3">
    <label class="form-label">Название *</label>
    <input @bind="newBook.Title" class="form-control" />
</div>

<div class="mb-3">
    <label class="form-label">Автор *</label>
    <input @bind="newBook.Author" class="form-control" />
</div>

<div class="mb-3">
    <label class="form-label">Жанр</label>
    <input @bind="newBook.Genre" class="form-control" />
</div>

<div class="mb-3">
    <label class="form-label">Год</label>
    <input type="number" @bind="newBook.Year" class="form-control" />
</div>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="SaveBook">💾 Сохранить</button>
    <button class="btn btn-secondary" @onclick="GoToBooks">📚 К списку книг</button>
</div>

@code {
    private Book newBook = new Book();

    private async Task SaveBook()
    {
        if (string.IsNullOrWhiteSpace(newBook.Title))
        {
            return;
        }
        if (string.IsNullOrWhiteSpace(newBook.Author))
        {
            return;
        }
        if (newBook.Year < 1000 || newBook.Year > 2025)
        {
            newBook.Year = 2000;
        }

        await BookService.AddBookAsync(newBook);
        Navigation.NavigateTo("/books");
    }

    private void GoToBooks()
    {
        Navigation.NavigateTo("/books");
    }
}